---
import AdminSidebar from "../components/admin/AdminSidebar.jsx";

const { title } = Astro.props;

const apiUrl = import.meta.env.PUBLIC_API_URL;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title} - Heatrow Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn-uicons.flaticon.com/uicons-regular-rounded/css/uicons-regular-rounded.css"
    />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon2.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon2.png" />
    <link rel="icon" type="image/png" sizes="128x128" href="/favicon2.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="bg-black text-white min-h-screen" style="font-family: 'Inter', system-ui, sans-serif;">
  <header class="w-full flex items-center justify-between px-6 py-3 bg-zinc-950 border-b border-zinc-800">
    <div class="flex items-center gap-4">
      <img src="/logo1.png" alt="Logo" class="w-10 h-10 object-contain" />
      <a href="/admin" class="text-sm font-semibold tracking-widest uppercase text-zinc-300 hover:text-white transition">
        Heatrow — Admin
      </a>
    </div>
    <div class="flex items-center gap-3">
      <a
        href="/"
        class="text-xs text-zinc-400 hover:text-white transition border border-zinc-800 px-3 py-1.5 hover:border-zinc-600"
      >
        ← Web pública
      </a>
      <button
        id="logout-btn"
        class="text-xs text-zinc-400 hover:text-white transition border border-zinc-800 px-3 py-1.5 hover:border-zinc-600"
      >
        Cerrar sesión
      </button>
    </div>
  </header>

  <div class="flex" style="min-height: calc(100vh - 49px);">
    <AdminSidebar client:load currentPath={Astro.url.pathname} />
    <main class="flex-1 p-8">
      <slot />
    </main>
  </div>
  <script define:vars={{ apiUrl }}>
    document.getElementById("logout-btn")?.addEventListener("click", async () => {
      await fetch(`${apiUrl}/auth/logout`, {
        method: "POST",
        credentials: "include",
      });
      window.location.href = "/admin/login";
    });
  </script>
  </body>
</html>
