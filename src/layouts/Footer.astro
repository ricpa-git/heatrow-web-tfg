---
// Footer compartido en todas las páginas
import FunctionalityPopup from "../components/ui/FunctionalityPopup.astro";
---

<footer class="py-10 px-8 bg-black border-t border-[oklch(50.5%_0.213_27.518)]">
  <div class="w-full flex flex-col gap-8">
    <!-- Newsletter -->
    <div
      class="flex flex-col md:flex-row items-center justify-between gap-4 pb-8"
    >
      <div>
        <p class="text-white font-black uppercase text-lg tracking-wide">
          ENTÉRATE ANTES QUE NADIE
        </p>
        <p class="text-zinc-500 text-sm">
          Suscríbete para saber primero cuándo salen las entradas.
        </p>
      </div>
      <form id="footer-newsletter" class="flex gap-0 w-full md:w-auto">
        <input
          type="email"
          name="email"
          placeholder="TU EMAIL"
          required
          class="bg-zinc-900 border border-zinc-700 focus:border-[oklch(50.5%_0.213_27.518)] text-white placeholder-zinc-500 px-4 py-2.5 text-sm outline-none transition-colors w-full md:w-64"
        />
        <button
          id="footer-subscribe-btn"
          type="submit"
          class="bg-[oklch(50.5%_0.213_27.518)] hover:bg-[oklch(45%_0.213_27.518)] text-white font-bold uppercase tracking-widest text-xs px-5 py-2.5 transition-colors whitespace-nowrap"
        >
          SUSCRIBIRSE
        </button>
      </form>
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <!-- Left: brand + links -->
      <div
        class="flex items-center gap-6 flex-wrap justify-center md:justify-start"
      >
        <span
          class="text-[oklch(50.5%_0.213_27.518)] font-black uppercase tracking-widest text-sm"
          >© HEATROW CLUB</span
        >
        <a
          href="/#galeria"
          class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] text-sm transition-colors"
          >Learn more</a
        >
        <a
          href="/contact"
          class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] text-sm transition-colors"
          >Support</a
        >
        <a
          href="/cookies"
          class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] text-sm transition-colors"
          >Cookies</a
        >
        <a
          href="/privacidad"
          class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] text-sm transition-colors"
          >Privacy</a
        >
      </div>

      <!-- Right: social icons -->
      <div class="flex items-center gap-5">
        <!-- Instagram -->
        <a
          href="https://www.instagram.com/heatrow.club/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] transition-colors"
          aria-label="Instagram de Heatrow"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
            ></path>
          </svg>
        </a>
        <!-- TikTok -->
        <a
          href="https://www.tiktok.com/@heatrow.club"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] transition-colors"
          aria-label="TikTok de Heatrow"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"
            ></path>
          </svg>
        </a>
        <!-- Spotify -->
        <a
          href="https://open.spotify.com/user/31r7gwoloprdbv6rykstaqbmsbse"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] transition-colors"
          aria-label="Spotify de Heatrow"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<!-- Back to top -->
<button
  id="back-to-top"
  class="fixed bottom-20 right-8 z-50 w-10 h-10 bg-[oklch(50.5%_0.213_27.518)] hover:bg-[oklch(45%_0.213_27.518)] text-white flex items-center justify-center transition-all duration-300 opacity-0 pointer-events-none"
  aria-label="Volver arriba"
>
  &#8593;
</button>
<!-- script back to top -->
<script>
  const btn = document.getElementById("back-to-top");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 400) {
      btn?.classList.remove("opacity-0", "pointer-events-none");
    } else {
      btn?.classList.add("opacity-0", "pointer-events-none");
    }
  });
  btn?.addEventListener("click", () =>
    window.scrollTo({ top: 0, behavior: "smooth" }),
  );
</script>

<!-- script para newsletter -->
<script>
  // Carga dinámica del SDK
  const script = document.createElement("script");
  script.src =
    "https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js";
  script.onload = () => {
    const emailjs = (window as any).emailjs;
    emailjs.init("YInKJUQPM6IOOpXF9");

    const form = document.getElementById(
      "footer-newsletter",
    ) as HTMLFormElement;
    const btn = form.querySelector(
      'button[type="submit"]',
    ) as HTMLButtonElement;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      e.stopPropagation();

      const email = (
        form.querySelector('input[name="email"]') as HTMLInputElement
      ).value;
      btn.disabled = true;
      btn.textContent = "ENVIANDO...";

      try {
        const API_URL =
          import.meta.env.PUBLIC_API_URL || "http://localhost:5257/api";
        const res = await fetch(`${API_URL}/subscribers`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });

        if (res.ok) {
          btn.textContent = "¡SUSCRITO!";
          form.reset();
          emailjs.send("service_zwo9za8", "template_cxd0vtq", {
            to_email: email,
            subject: "¡Bienvenido a Heatrow Club!",
            message:
              "Gracias por suscribirte a Heatrow Club.\n\nSerás el primero en enterarte de nuestros próximos eventos y en conseguir entradas antes que nadie.\n\n¡See you on the floor!\n\n— Heatrow Club",
            unsubscribe_url: `${window.location.origin}/unsubscribe?email=${encodeURIComponent(email)}`,
          });
        } else if (res.status === 409) {
          btn.textContent = "YA ESTÁS SUSCRITO";
        } else {
          btn.textContent = "ERROR";
        }
      } catch {
        btn.textContent = "ERROR";
      } finally {
        setTimeout(() => {
          btn.disabled = false;
          btn.textContent = "SUSCRIBIRSE";
        }, 3000);
      }
    });
  };
  document.head.appendChild(script);
</script>

<FunctionalityPopup triggers={["#footer-subscribe-btn"]} />

