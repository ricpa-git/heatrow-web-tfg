---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "EVENT" },
  { href: "/gallery", label: "GALLERY" },
  { href: "/contact", label: "CONTACT" },
  { href: "/tickets", label: "TICKETS" },
  { href: "/radio", label: "RADIO" }
];
---

<!-- Navbar -->
<nav class="fixed top-0 w-full bg-black z-50 shadow-lg">
  <div class="w-full px-8">
    <div class="flex justify-between items-center h-32">
      <div class="hidden xl:flex gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`font-semibold transition-colors ${currentPath === link.href ? "text-white underline underline-offset-4" : "text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)]"}`}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Logo centrado -->
      <a href="/" class="absolute left-1/2 -translate-x-1/2">
        <img src="/logo1.png" alt="Heatrow Club" class="h-28 w-auto" />
      </a>

      <!-- Hamburger — mobile + tablet -->
      <button id="mobile-menu-btn" class="xl:hidden ml-auto focus:outline-none z-10" aria-label="Abrir menú">
        <div class="flex flex-col justify-center gap-1.5 w-7 h-7 cursor-pointer">
          <span id="line1" class="block h-0.5 w-7 bg-[oklch(50.5%_0.213_27.518)] transition-all duration-300 origin-center"></span>
          <span id="line2" class="block h-0.5 w-7 bg-[oklch(50.5%_0.213_27.518)] transition-all duration-300"></span>
          <span id="line3" class="block h-0.5 w-7 bg-[oklch(50.5%_0.213_27.518)] transition-all duration-300 origin-center"></span>
        </div>
      </button>
    </div>
  </div>

  <!-- Mobile + tablet menu dropdown -->
  <div id="mobile-menu" class="hidden flex-col xl:hidden absolute top-full left-0 right-0 bg-black border-t border-[oklch(50.5%_0.213_27.518)] z-50 px-8 py-6 gap-5">
    {navLinks.map(link => (
      <a
        href={link.href}
        class={`font-semibold transition-colors py-2 ${currentPath === link.href ? "text-white underline underline-offset-4" : "text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)]"}`}
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<!-- Ticker / Marquee -->
<div id="ticker-bar" class="fixed top-32 w-full z-40 overflow-hidden bg-[oklch(50.5%_0.213_27.518)] py-3 cursor-pointer">
  <div class="ticker-track flex whitespace-nowrap">
    <span class="ticker-content text-white font-bold uppercase text-sm tracking-widest">
      HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp;
    </span>
    <span class="ticker-content text-white font-bold uppercase text-sm tracking-widest" aria-hidden="true">
      HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp;
    </span>
  </div>
</div>

<style>
  .ticker-track { animation: ticker 15s linear infinite; }
  .ticker-track:hover { animation-play-state: paused; }
  @keyframes ticker {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>

<script>
  document.getElementById('ticker-bar')?.addEventListener('click', () => {
    window.location.href = '/tickets';
  });

  const mobileBtn  = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    const line1 = document.getElementById('line1');
    const line2 = document.getElementById('line2');
    const line3 = document.getElementById('line3');

    if (isOpen) {
      mobileMenu?.classList.remove('flex');
      mobileMenu?.classList.add('hidden');
      line1?.classList.remove('rotate-45', 'translate-y-2');
      line2?.classList.remove('opacity-0');
      line3?.classList.remove('-rotate-45', '-translate-y-2');
    } else {
      mobileMenu?.classList.remove('hidden');
      mobileMenu?.classList.add('flex');
      line1?.classList.add('rotate-45', 'translate-y-2');
      line2?.classList.add('opacity-0');
      line3?.classList.add('-rotate-45', '-translate-y-2');
    }
  });
</script>