---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "EVENT" },
  { href: "/gallery", label: "GALLERY" },
  { href: "/contact", label: "CONTACT" },
  { href: "/tickets", label: "TICKETS" },
  { href: "/radio", label: "RADIO" }
];
---

<!-- Navbar -->
<nav class="fixed top-0 w-full bg-black z-50 shadow-lg">
  <div class="w-full px-8">
    <div class="flex justify-between items-center h-32">
      <div class="hidden xl:flex gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`font-semibold transition-colors ${currentPath === link.href ? "text-white underline underline-offset-4" : "text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)]"}`}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Logo centrado -->
      <a href="/" class="absolute left-1/2 -translate-x-1/2">
        <img src="/logo1.png" alt="Heatrow Club" class="h-28 w-auto" />
      </a>

      <!-- Hamburger — mobile + tablet -->
      <button id="mobile-menu-btn" class="xl:hidden ml-auto focus:outline-none z-40" aria-label="Abrir menú">
        <div class="flex flex-col justify-center gap-1.5 w-7 h-7 cursor-pointer">
          <span id="line1" class="block h-0.5 w-7 bg-[oklch(50.5%_0.213_27.518)] transition-all duration-300 origin-center"></span>
          <span id="line2" class="block h-0.5 w-7 bg-[oklch(50.5%_0.213_27.518)] transition-all duration-300"></span>
          <span id="line3" class="block h-0.5 w-7 bg-[oklch(50.5%_0.213_27.518)] transition-all duration-300 origin-center"></span>
        </div>
      </button>
    </div>
  </div>

  <!-- Sidebar Menu - Full Screen -->
  <div id="mobile-menu" class="fixed inset-0 bg-black xl:hidden z-30 transform -translate-x-full transition-transform duration-500 ease-in-out overflow-y-auto">
    <!-- Overlay oscuro sutil -->
    <div class="absolute inset-0 bg-gradient-to-b from-[oklch(50.5%_0.213_27.518)]/5 to-transparent pointer-events-none"></div>
    
    <!-- Contenido del menú -->
    <div class="relative h-full flex flex-col px-8 pt-40 pb-20">
      <!-- Links de navegación -->
      <div class="space-y-8 flex-1">
        {navLinks.map((link, index) => (
          <a
            href={link.href}
            data-index={index}
            class={`nav-link block text-3xl sm:text-5xl font-black uppercase tracking-widest transition-all duration-300 opacity-0 translate-y-4 ${
              currentPath === link.href 
                ? "text-white" 
                : "text-[oklch(50.5%_0.213_27.518)] hover:text-white"
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Redes sociales al fondo -->
      <div class="border-t border-[oklch(50.5%_0.213_27.518)]/20 pt-8">
        <p class="text-[oklch(50.5%_0.213_27.518)] text-sm uppercase tracking-widest mb-6 font-semibold">Follow Us</p>
        <div class="flex gap-6">
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/heatrow.club/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] transition-colors"
            aria-label="Instagram de Heatrow"
          >
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
              ></path>
            </svg>
          </a>
          <!-- TikTok -->
          <a
            href="https://www.tiktok.com/@heatrow.club"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] transition-colors"
            aria-label="TikTok de Heatrow"
          >
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"
              ></path>
            </svg>
          </a>
          <!-- Spotify -->
          <a
            href="https://open.spotify.com/user/31r7gwoloprdbv6rykstaqbmsbse"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] transition-colors"
            aria-label="Spotify de Heatrow"
          >
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>

<!-- Ticker / Marquee -->
<div id="ticker-bar" class="fixed top-32 w-full z-40 overflow-hidden bg-[oklch(50.5%_0.213_27.518)] py-3 cursor-pointer">
  <div class="ticker-track flex whitespace-nowrap">
    <span class="ticker-content text-white font-bold uppercase text-sm tracking-widest">
      HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp;
    </span>
    <span class="ticker-content text-white font-bold uppercase text-sm tracking-widest" aria-hidden="true">
      HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 30/07 // &ldquo;KANYE WEST AFTER CONCERT&rdquo; &nbsp;&mdash;&nbsp;
    </span>
  </div>
</div>

<style>
  .ticker-track { animation: ticker 15s linear infinite; }
  .ticker-track:hover { animation-play-state: paused; }
  @keyframes ticker {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>

<script>
  document.getElementById('ticker-bar')?.addEventListener('click', () => {
    window.location.href = '/tickets';
  });

  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  let isMenuOpen = false;

  mobileBtn?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen;
    const line1 = document.getElementById('line1');
    const line2 = document.getElementById('line2');
    const line3 = document.getElementById('line3');
    const navLinks = document.querySelectorAll('.nav-link');

    if (isMenuOpen) {
      // Abrir menú
      mobileMenu?.classList.remove('-translate-x-full');
      line1?.classList.add('rotate-45', 'translate-y-2');
      line2?.classList.add('opacity-0');
      line3?.classList.add('-rotate-45', '-translate-y-2');

      // Animar links en cascada
      navLinks.forEach((link, index) => {
        setTimeout(() => {
          link.classList.remove('opacity-0', 'translate-y-4');
        }, 50 + index * 50);
      });
    } else {
      // Cerrar menú
      mobileMenu?.classList.add('-translate-x-full');
      line1?.classList.remove('rotate-45', 'translate-y-2');
      line2?.classList.remove('opacity-0');
      line3?.classList.remove('-rotate-45', '-translate-y-2');

      // Desanimar links
      navLinks.forEach((link) => {
        link.classList.add('opacity-0', 'translate-y-4');
      });
    }
  });

  // Cerrar menú al hacer click en un link
  document.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', () => {
      isMenuOpen = false;
      mobileMenu?.classList.add('-translate-x-full');
      const line1 = document.getElementById('line1');
      const line2 = document.getElementById('line2');
      const line3 = document.getElementById('line3');
      line1?.classList.remove('rotate-45', 'translate-y-2');
      line2?.classList.remove('opacity-0');
      line3?.classList.remove('-rotate-45', '-translate-y-2');
    });
  });
</script>