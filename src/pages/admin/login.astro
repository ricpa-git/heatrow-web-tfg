---
export const prerender = false;
const backendUrl = import.meta.env.BACKEND_API_URL ?? "http://localhost:5257/api";
try {
  const res = await fetch(`${backendUrl}/auth/me`, {
    headers: { cookie: Astro.request.headers.get("cookie") || "" }
  });
  if (res.ok) {
    const data = await res.json();
    if (data.role === "admin") return Astro.redirect("/admin");
  }
} catch {}
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Admin — Heatrow Club</title>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon2.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
</head>
<body class="bg-black min-h-screen flex items-center justify-center" style="font-family: 'Inter', system-ui, sans-serif;">
  <div class="w-full max-w-xs">
    <div class="mb-8 text-center">
      <img src="/logo1.png" alt="Heatrow" class="w-12 h-12 object-contain mx-auto mb-4" />
      <p class="text-xs text-zinc-500 uppercase tracking-widest">Panel de administración</p>
    </div>

    <div class="border border-zinc-800 bg-zinc-950">
      <div class="px-6 py-5 border-b border-zinc-800">
        <h1 class="text-sm font-semibold text-white">Iniciar sesión</h1>
      </div>
      <div class="px-6 py-5 flex flex-col gap-3">
        <div id="error" class="hidden text-red-400 text-xs py-2 px-3 border border-red-900 bg-red-950"></div>
        <input id="username" type="text" placeholder="Usuario"
          class="w-full bg-zinc-900 border border-zinc-800 text-white px-3 py-2 text-sm outline-none focus:border-zinc-600 transition" />
        <input id="password" type="password" placeholder="Contraseña"
          class="w-full bg-zinc-900 border border-zinc-800 text-white px-3 py-2 text-sm outline-none focus:border-zinc-600 transition" />
      </div>
      <div class="px-6 py-4 border-t border-zinc-800">
        <button id="loginBtn" class="w-full bg-white text-black font-semibold py-2 text-sm hover:bg-zinc-100 transition">
          Entrar
        </button>
      </div>
    </div>

    <p class="text-center text-zinc-700 text-xs mt-6">&copy; Heatrow Club</p>
  </div>
</body>
</html>

  <script>
    const loginBtn = document.getElementById("loginBtn") as HTMLButtonElement;
    const usernameEl = document.getElementById("username") as HTMLInputElement;
    const passwordEl = document.getElementById("password") as HTMLInputElement;
    const errorEl = document.getElementById("error") as HTMLElement;

    async function doLogin() {
      const username = usernameEl.value.trim();
      const password = passwordEl.value;
      if (!username || !password) return;

      loginBtn.disabled = true;
      loginBtn.textContent = "Entrando...";
      errorEl.classList.add("hidden");

      try {
        const res = await fetch(`/api/auth/login`, {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ username, password })
        });

        if (!res.ok) {
          errorEl.textContent = "Usuario o contraseña incorrectos";
          errorEl.classList.remove("hidden");
          loginBtn.disabled = false;
          loginBtn.textContent = "Entrar";
          return;
        }

        window.location.href = "/admin";
      } catch {
        errorEl.textContent = "Error de conexión con el servidor";
        errorEl.classList.remove("hidden");
        loginBtn.disabled = false;
        loginBtn.textContent = "Entrar";
      }
    }

    loginBtn.addEventListener("click", doLogin);
    passwordEl.addEventListener("keydown", (e) => { if (e.key === "Enter") doLogin(); });
  </script>