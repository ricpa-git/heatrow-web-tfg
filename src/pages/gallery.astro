---
import Layout from "../layouts/Layout.astro";
import GalleryGrid from "../components/ui/Gallery.jsx";
---

<Layout title="HEATROW CLUB | Gallery">
  <main class="bg-black pt-48 pb-20 px-4 md:px-8">
    <div class="max-w-6xl mx-auto">
      <h1
        class="text-4xl md:text-6xl font-black text-center text-[oklch(50.5%_0.213_27.518)] mb-4"
      >
        SEE WHAT'S INSIDE
      </h1>
      <p
        class="text-white text-center font-semibold uppercase tracking-widest text-sm mb-10"
      >
        TODAS NUESTRAS FOTOS Y VIDEOS
      </p>
      <GalleryGrid client:load />
    </div>
  </main>
</Layout>
