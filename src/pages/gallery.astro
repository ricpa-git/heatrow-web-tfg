---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Heatrow Club | Gallery">
  <!-- Gallery Content -->
  <main class="bg-black pt-52 pb-24 px-8">

    <!-- Header -->
    <div class="text-center mb-14">
      <h1 class="text-5xl md:text-7xl font-black uppercase text-[oklch(50.5%_0.213_27.518)] tracking-wide">
        SEE WHAT&rsquo;S INSIDE
      </h1>
      <p class="text-white text-sm uppercase tracking-widest mt-4">Todas nuestras fotos y videos</p>
    </div>

    <!-- Row 1: 3 columns, left/right 2 imgs, center 3 imgs -->
    <div class="flex gap-3 w-full" style="height: 80vh;">

      <!-- Left column: 2 images -->
      <div class="flex flex-col gap-3 w-1/3">
        <div class="flex-1 bg-zinc-900 overflow-hidden">
          <img src="/gallery/foto1.jpg" alt="Heatrow foto 1" class="w-full h-full object-cover" />
        </div>
        <div class="flex-1 bg-zinc-900 overflow-hidden">
          <img src="/gallery/foto2.jpg" alt="Heatrow foto 2" class="w-full h-full object-cover" />
        </div>
      </div>

      <!-- Center column: 3 images -->
      <div class="flex flex-col gap-3 w-1/3">
        <div class="flex-1 bg-zinc-900 overflow-hidden">
          <img src="/gallery/foto3.jpg" alt="Heatrow foto 3" class="w-full h-full object-cover" />
        </div>
        <div class="flex-1 bg-zinc-900 overflow-hidden">
          <img src="/gallery/foto4.jpg" alt="Heatrow foto 4" class="w-full h-full object-cover" />
        </div>
        <div class="flex-1 bg-zinc-900 overflow-hidden">
          <img src="/gallery/foto5.jpg" alt="Heatrow foto 5" class="w-full h-full object-cover" />
        </div>
      </div>

      <!-- Right column: 2 images -->
      <div class="flex flex-col gap-3 w-1/3">
        <div class="flex-1 bg-zinc-900 overflow-hidden">
          <img src="/gallery/foto6.jpg" alt="Heatrow foto 6" class="w-full h-full object-cover" />
        </div>
        <div class="flex-1 bg-zinc-900 overflow-hidden">
          <img src="/gallery/foto7.jpg" alt="Heatrow foto 7" class="w-full h-full object-cover" />
        </div>
      </div>

    </div>

    <!-- Row 2: 3 more images full-width -->
    <div class="flex gap-3 w-full mt-3" style="height: 60vh;">
      <div class="flex-1 bg-zinc-900 overflow-hidden">
        <img src="/gallery/foto8.jpg" alt="Heatrow foto 8" class="w-full h-full object-cover" />
      </div>
      <div class="flex-1 bg-zinc-900 overflow-hidden">
        <img src="/gallery/foto9.jpg" alt="Heatrow foto 9" class="w-full h-full object-cover" />
      </div>
      <div class="flex-1 bg-zinc-900 overflow-hidden">
        <img src="/gallery/foto10.jpg" alt="Heatrow foto 10" class="w-full h-full object-cover" />
      </div>
    </div>

  </main>

</Layout>
