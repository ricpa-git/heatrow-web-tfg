---
import Layout from "../layouts/Layout.astro";
import DemoPopup from "../components/ui/DemoPopup.astro";
---

<Layout title="HEATROW CLUB | Home">
  <DemoPopup />

  <!--Estilos para que el logo gire -->
  <style>
    @keyframes spin-slow {
      from {
        transform: rotate(0deg);
      }
      to {
        transform: rotate(360deg);
      }
    }
    .animate-spin-slow {
      animation: spin-slow 8s linear infinite;
    }
    @keyframes flip3d {
      0% {
        transform: perspective(600px) rotateY(0deg);
      }
      100% {
        transform: perspective(600px) rotateY(360deg);
      }
    }
    .animate-flip3d {
      animation: flip3d 4s linear infinite;
      transform-style: preserve-3d;
    }

    .events-scroller {
      scroll-snap-type: x mandatory;
      scroll-padding-inline: var(--events-edge-pad, 1rem);
      padding-inline: var(--events-edge-pad, 1rem);
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .events-scroller::-webkit-scrollbar {
      display: none;
    }

    .event-card {
      scroll-snap-align: center;
      transition: transform 0.35s ease, opacity 0.35s ease;
      opacity: 0.55;
      transform: scale(0.9);
    }

    .event-card[data-active="true"] {
      opacity: 1;
      transform: scale(1);
    }

    @keyframes swipe-nudge {
      0%,
      100% {
        transform: translateX(0);
      }
      50% {
        transform: translateX(6px);
      }
    }

    .swipe-hint-arrow {
      display: inline-block;
      animation: swipe-nudge 1s ease-in-out infinite;
    }

    .swipe-hint-arrow-left {
      animation-direction: reverse;
    }

    .event-card[data-active="false"] .purchase-link {
      pointer-events: none;
      opacity: 0.4;
      cursor: not-allowed;
    }
  </style>

  <!-- Hero Section -->
  <section
    id="evento"
    class="min-h-screen flex items-center justify-center relative bg-black pt-32 overflow-hidden"
  >
    <!-- Video de fondo -->
    <video
      class="absolute inset-0 w-full h-full object-cover opacity-30"
      autoplay
      muted
      loop
      playsinline
    >
      <source src="/video1.mp4" type="video/mp4" />
    </video>
    <!-- Overlay oscuro sobre el video -->
    <div class="absolute inset-0 bg-black/50"></div>

    <!-- Contenido -->
    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
      <img
        src="/logo1.png"
        alt="Heatrow Club"
        class="w-72 md:w-96 mx-auto mb-8 animate-flip3d"
      />
      <p class="text-xl md:text-2xl mb-8 text-gray-300">
        THE MUSIC THEY DON'T PLAY
      </p>

      <!-- CTA Button -->
      <a
        href="#entradas"
        class="inline-block bg-[oklch(50.5%_0.213_27.518)] hover:bg-[oklch(45%_0.213_27.518)] text-white px-12 py-4 rounded-none text-xl font-bold transition-all duration-300 shadow-xl uppercase tracking-wider"
      >
        Consigue tus entradas
      </a>
    </div>
  </section>

  <!--ABOUT US -->
  <section
    id="galeria"
    class="py-20 px-4 bg-black border-t border-[oklch(50.5%_0.213_27.518)] scroll-mt-28"
  >
    <div class="max-w-7xl mx-auto">
      <h2
        class="text-4xl md:text-6xl font-black mb-4 text-center text-[oklch(50.5%_0.213_27.518)]"
      >
        ABOUT US
      </h2>
      <div class="w-32 h-1 bg-[oklch(50.5%_0.213_27.518)] mx-auto mb-16"></div>

      <!-- Imagen About Us -->
      <div class="overflow-hidden">
        <div
          class="aspect-video bg-zinc-900 flex items-center justify-center border border-red-600 overflow-hidden"
        >
          <img
            src="/gallery/foto5.jpeg"
            class="w-full h-full object-cover"
            alt="Foto Heatrow"
          />
        </div>
      </div>

      <!-- Botón Ver más fotos -->
      <div class="flex justify-center mt-10">
        <a
          href="/gallery"
          class="inline-block border border-[oklch(50.5%_0.213_27.518)] text-[oklch(50.5%_0.213_27.518)] hover:bg-[oklch(50.5%_0.213_27.518)] hover:text-white text-xs font-bold uppercase tracking-widest px-6 py-3 transition-colors w-fit"
        >
          VER MÁS FOTOS
        </a>
      </div>

      <!-- Texto About Us -->
      <div class="max-w-3xl mx-auto mt-16 text-center space-y-6">
        <p class="text-gray-300 text-lg leading-relaxed">
          Ubicada en la latente ciudad de Madrid, Heat Row es un proyecto que
          nace con la ambición de generar una comunidad de la mano del Hip-hop,
          el Trap y el Rap. Nuestro objetivo es hacer eco de este sonido y que
          las personas sientan que tienen un hogar al que ir, disfrutar y
          pertenecer. Esta idea emerge del sentimiento común de un grupo de
          amigos que motivados por una misma pasión desean compartirla y
          alimentarla con más gente en el camino, generando un ambiente positivo
          y cargado de energía.
        </p>
        <p class="text-gray-300 text-lg leading-relaxed">
          Desde un "Mosh Pit" a morir hasta vibear las melodías sintiéndote un
          "Pretty MF", nuestra propuesta es dar a escuchar más de lo que muchas
          fiestas en esta ciudad consideran que es el Hip-Hop.
        </p>
        <p class="text-white text-lg font-semibold leading-relaxed">
          Este es el punto de partida, la primera llama ya ha sido encendida,
          todo empieza ahora y tienes que ser parte de ello.
        </p>
      </div>
    </div>
  </section>

  <!-- Upcoming Events Section -->
  <section
    id="entradas"
    class="py-20 px-4 bg-black border-t border-[oklch(50.5%_0.213_27.518)] scroll-mt-28"
  >
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-4xl md:text-6xl font-black mb-4 text-center text-[oklch(50.5%_0.213_27.518)]"
      >
        UPCOMING EVENTS
      </h2>
      <div class="w-32 h-1 bg-[oklch(50.5%_0.213_27.518)] mx-auto mb-16"></div>

      <div
        class="md:hidden flex items-center justify-center gap-2 mb-5 text-[11px] uppercase tracking-[0.2em] text-zinc-400"
      >
        <span class="swipe-hint-arrow swipe-hint-arrow-left text-[oklch(50.5%_0.213_27.518)]">&#8592;</span>
        <span>Desliza para ver los eventos</span>
        <span class="swipe-hint-arrow text-[oklch(50.5%_0.213_27.518)]">&#8594;</span>
      </div>

      <div
        id="events-scroller"
        class="events-scroller flex gap-6 overflow-x-auto pb-4"
      >
      <!-- CADA ARTICLE ES UN EVENTO -->
        <article
          class="event-card flex-shrink-0 w-[82vw] sm:w-[62vw] md:w-[44vw] lg:w-[26vw] xl:w-[22vw] max-w-[340px] cursor-pointer"
          data-event="kanye"
          data-active="true"
        >
          <div class="flex flex-col">
            <div class="relative w-full aspect-[3/4] border border-red-600 overflow-hidden">
              <video
                autoplay
                muted
                loop
                playsinline
                class="absolute inset-0 w-full h-full object-cover object-center block"
              >
                <source src="/videoye.mp4" type="video/mp4" />
                Tu navegador no soporta el elemento video
              </video>
            </div>
            <div class="mt-4">
              <p
                class="text-white font-black text-xl uppercase leading-tight mb-3"
              >
                KANYE WEST AFTER CONCERT<br />TEATRO MAGNO, MADRID - 30/07
              </p>
              <a
                href="/tickets/evento-1"
                class="purchase-link inline-block border border-[oklch(50.5%_0.213_27.518)] text-[oklch(50.5%_0.213_27.518)] hover:bg-[oklch(50.5%_0.213_27.518)] hover:text-white text-xs font-bold uppercase tracking-widest px-6 py-3 transition-colors w-fit"
              >
                COMPRAR ENTRADA
              </a>
            </div>
          </div>
        </article>

        <article
          class="event-card flex-shrink-0 w-[82vw] sm:w-[62vw] md:w-[44vw] lg:w-[26vw] xl:w-[22vw] max-w-[340px] cursor-pointer"
          data-active="false"
        >
          <div class="flex flex-col">
            <div
              class="w-full aspect-[3/4] border border-red-600 bg-zinc-900/70 flex items-center justify-center"
              aria-label="Proximamente"
            >
              <span class="text-zinc-300 text-lg md:text-xl font-black uppercase tracking-wider">
                PROXIMAMENTE...
              </span>
            </div>
            <div class="mt-4">
              <p
                class="text-white font-black text-xl uppercase leading-tight mb-3"
              >
                ?????<br />SALA CLAMORES, MADRID - 05/05
              </p>
              <a
                href="/tickets/evento-2"
                class="purchase-link inline-block border border-[oklch(50.5%_0.213_27.518)] text-[oklch(50.5%_0.213_27.518)] hover:bg-[oklch(50.5%_0.213_27.518)] hover:text-white text-xs font-bold uppercase tracking-widest px-6 py-3 transition-colors w-fit"
              >
                COMPRAR ENTRADA
              </a>
            </div>
          </div>
        </article>

        <!-- <article
          class="event-card flex-shrink-0 w-[82vw] sm:w-[62vw] md:w-[44vw] lg:w-[26vw] xl:w-[22vw] max-w-[340px] cursor-pointer"
          data-active="false"
        >
          <div class="flex flex-col">
            <div
              class="w-full aspect-[3/4] border border-red-600 bg-zinc-900/70 flex items-center justify-center"
              aria-label="Proximamente"
            >
              <span class="text-zinc-300 text-lg md:text-xl font-black uppercase tracking-wider">
                PROXIMAMENTE...
              </span>
            </div>
            <div class="mt-4">
              <p
                class="text-white font-black text-xl uppercase leading-tight mb-3"
              >
                SUMMER HEAT SESSION<br />TEATRO MAGNO, MADRID - 24/08
              </p>
              <!-- <a
                href="/tickets"
                class="inline-block border border-[oklch(50.5%_0.213_27.518)] text-[oklch(50.5%_0.213_27.518)] hover:bg-[oklch(50.5%_0.213_27.518)] hover:text-white text-xs font-bold uppercase tracking-widest px-6 py-3 transition-colors w-fit"
              >
                COMPRAR ENTRADA
              </a> -->
            </div>
          </div>
        </article>
      </div>
    </div>
    <!-- <DjsSection client:load /> -->
  </section>

  <script>
    const eventsScroller = document.getElementById("events-scroller") as HTMLDivElement | null;

    if (eventsScroller) {
      let cards = Array.from(eventsScroller.querySelectorAll(".event-card")) as HTMLElement[];
      const kanyeCard = eventsScroller.querySelector('[data-event="kanye"]') as HTMLElement | null;

      // DEJA EL EVENTO DE KANYE AL CENTRO AUTOMATICAMENTE CADA VEZ QUE CARGA LA PAG
      if (kanyeCard && cards.length > 1 && cards[0] === kanyeCard) {
        eventsScroller.insertBefore(cards[1], kanyeCard);
        cards = Array.from(eventsScroller.querySelectorAll(".event-card")) as HTMLElement[];
      }

      const updateEdgePadding = () => {
        const baseCard = cards[0];
        if (!baseCard) {
          return;
        }

        const edgePad = Math.max(16, (eventsScroller.clientWidth - baseCard.clientWidth) / 2);
        eventsScroller.style.setProperty("--events-edge-pad", `${edgePad}px`);
      };

      const centerCard = (card: HTMLElement, behavior: ScrollBehavior = "smooth") => {
        const scrollerRect = eventsScroller.getBoundingClientRect();
        const cardRect = card.getBoundingClientRect();
        const targetLeft =
          eventsScroller.scrollLeft +
          (cardRect.left - scrollerRect.left) -
          (eventsScroller.clientWidth - cardRect.width) / 2;
        const maxLeft = eventsScroller.scrollWidth - eventsScroller.clientWidth;
        const clampedLeft = Math.max(0, Math.min(targetLeft, maxLeft));

        eventsScroller.scrollTo({
          left: clampedLeft,
          behavior,
        });
      };

      const swapCards = (first: HTMLElement, second: HTMLElement) => {
        if (first === second) {
          return;
        }

        const firstNext = first.nextSibling;
        const secondNext = second.nextSibling;

        if (firstNext === second) {
          eventsScroller.insertBefore(second, first);
          eventsScroller.insertBefore(first, secondNext);
          return;
        }

        if (secondNext === first) {
          eventsScroller.insertBefore(first, second);
          eventsScroller.insertBefore(second, firstNext);
          return;
        }

        eventsScroller.insertBefore(first, secondNext);
        eventsScroller.insertBefore(second, firstNext);
      };

      const setActiveCard = () => {
        const scrollerRect = eventsScroller.getBoundingClientRect();
        const scrollerCenter = scrollerRect.left + scrollerRect.width / 2;
        let closestCard: HTMLElement | null = null;
        let closestDistance = Number.POSITIVE_INFINITY;

        cards.forEach((card) => {
          const rect = card.getBoundingClientRect();
          const cardCenter = rect.left + rect.width / 2;
          const distance = Math.abs(scrollerCenter - cardCenter);

          if (distance < closestDistance) {
            closestDistance = distance;
            closestCard = card;
          }
        });

        cards.forEach((card) => {
          card.dataset.active = card === closestCard ? "true" : "false";
        });
      };

      const getActiveCard = () =>
        cards.find((card) => card.dataset.active === "true") || cards[0] || null;

      eventsScroller.addEventListener("scroll", setActiveCard, { passive: true });
      window.addEventListener("resize", () => {
        updateEdgePadding();
        const activeCard = getActiveCard();
        if (activeCard) {
          centerCard(activeCard, "auto");
        }
      });

      cards.forEach((card) => {
        card.addEventListener("click", (event) => {
          const target = event.target as HTMLElement;
          if (target.closest("a, button")) {
            return;
          }

          const activeCard = cards.find((item) => item.dataset.active === "true");

          if (!activeCard || activeCard === card) {
            centerCard(card);
            return;
          }

          swapCards(activeCard, card);
          cards = Array.from(eventsScroller.querySelectorAll(".event-card")) as HTMLElement[];
          card.dataset.active = "true";
          activeCard.dataset.active = "false";
          centerCard(card);
        });
      });

      const initialCard =
        (eventsScroller.querySelector('[data-event="kanye"]') as HTMLElement | null) ||
        cards[0] ||
        null;
      if (initialCard) {
        cards.forEach((card) => {
          card.dataset.active = card === initialCard ? "true" : "false";
        });
      }

      const initializeCarousel = () => {
        updateEdgePadding();
        const activeCard = getActiveCard();
        if (activeCard) {
          centerCard(activeCard, "auto");
        }
        setActiveCard();
      };

      requestAnimationFrame(() => requestAnimationFrame(initializeCarousel));
      window.addEventListener("load", initializeCarousel, { once: true });
    }
  </script>

  <!-- Find Us -->
  <section
    id="contacto"
    class="py-20 px-8 bg-black border-t border-[oklch(50.5%_0.213_27.518)] scroll-mt-28"
  >
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <!-- Left: info -->
      <div>
        <h2
          class="text-5xl md:text-7xl font-black uppercase text-[oklch(50.5%_0.213_27.518)] mb-4"
        >
          FIND US
        </h2>
        <p class="text-white font-bold uppercase tracking-widest text-sm mb-1">
          TEATRO MAGNO
        </p>
        <p class="text-white font-bold uppercase tracking-widest text-sm mb-6">
          28014 MADRID
        </p>
        <a
          href=https://www.google.com/maps/place/Teatro+Magno/@40.4173074,-3.6983218,17z/data=!3m1!4b1!4m6!3m5!1s0xd42291c08455f2d:0x484149f164cdd1eb!8m2!3d40.4173074!4d-3.6983218!16s%2Fg%2F11rdbdrd5v?entry=ttu&g_ep=EgoyMDI2MDQwNS4wIKXMDSoASAFQAw%3D%3D
          target="_blank"
          rel="noopener noreferrer"
          class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] text-sm underline underline-offset-4 transition-colors"
        >
          Ver Ubicación
        </a>
      </div>

      <!-- Right: map -->
      <div class="w-64 h-64 md:w-80 md:h-80 overflow-hidden border border-[oklch(50.5%_0.213_27.518)]">
        <iframe
          width="100%"
          height="100%"
          frameborder="0"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3037.61804948712!2d-3.7008967234930426!3d40.41731145560309!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd42291c08455f2d%3A0x484149f164cdd1eb!2sTeatro%20Magno!5e0!3m2!1ses!2ses!4v1775568497175!5m2!1ses!2ses" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </section>
</Layout>
