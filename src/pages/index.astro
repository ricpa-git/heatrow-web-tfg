---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Heatrow Club | Hip Hop & Trap Madrid">
  <!-- Navbar -->
  <nav class="fixed top-0 w-full bg-black z-50 shadow-lg">
    <div class="w-full px-8">
      <div class="flex justify-between items-center h-32">
        <div class="hidden md:flex gap-8">
          <a
            href="/"
            class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] font-semibold transition-colors"
          >
            EVENT
          </a>

          <a
            href="/gallery"
            class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] font-semibold transition-colors"
          >
            GALLERY
          </a>
          <a
            href="/contact"
            class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] font-semibold transition-colors"
          >
            CONTACT
          </a>
          <a
            href="/tickets"
            class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] font-semibold transition-colors"
          >
            TICKETS
          </a>
        </div>

        <!-- Logo centrado -->
        <a href="/" class="absolute left-1/2 -translate-x-1/2">
          <img src="/logo1.png" alt="Heatrow Club" class="h-28 w-auto" />
        </a>

        <!-- Hamburger — mobile only -->
        <button id="mobile-menu-btn" class="md:hidden ml-auto text-[oklch(50.5%_0.213_27.518)] focus:outline-none z-10" aria-label="Abrir menú">
          <svg id="icon-open" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-7 h-7 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>

      </div>
    </div>

    <!-- Mobile menu dropdown -->
    <div id="mobile-menu" class="hidden flex-col md:hidden absolute top-full left-0 right-0 bg-black border-t border-[oklch(50.5%_0.213_27.518)] z-50 px-8 py-6 gap-5">
      <a href="/" class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] font-semibold transition-colors py-2">EVENT</a>
      <a href="/gallery" class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] font-semibold transition-colors py-2">GALLERY</a>
      <a href="/contact" class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] font-semibold transition-colors py-2">CONTACT</a>
      <a href="/tickets" class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] font-semibold transition-colors py-2">TICKETS</a>
    </div>
  </nav>

  <!-- Ticker / Marquee -->
  <div id="ticker-bar" class="fixed top-32 w-full z-40 overflow-hidden bg-[oklch(50.5%_0.213_27.518)] py-3 cursor-pointer">
    <div class="ticker-track flex whitespace-nowrap">
      <span class="ticker-content text-white font-bold uppercase text-sm tracking-widest">
        HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp;
      </span>
      <span class="ticker-content text-white font-bold uppercase text-sm tracking-widest" aria-hidden="true">
        HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp; HEATROW CLUB 27/03 // &ldquo;BACK TO 2016!&rdquo; &nbsp;&mdash;&nbsp;
      </span>
    </div>
  </div>

  <style>
    .ticker-track {
      animation: ticker 15s linear infinite;
    }
    .ticker-track:hover {
      animation-play-state: paused;
    }
    @keyframes ticker {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @keyframes spin-slow {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }
    .animate-spin-slow {
      animation: spin-slow 8s linear infinite;
    }
    @keyframes flip3d {
      0%   { transform: perspective(600px) rotateY(0deg); }
      100% { transform: perspective(600px) rotateY(360deg); }
    }
    .animate-flip3d {
      animation: flip3d 4s linear infinite;
      transform-style: preserve-3d;
    }
  </style>

  <script>
    document.getElementById('ticker-bar')?.addEventListener('click', () => {
      window.location.href = '/tickets';
    });

    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');
    mobileBtn?.addEventListener('click', () => {
      const isOpen = !mobileMenu?.classList.contains('hidden');
      if (isOpen) {
        mobileMenu?.classList.remove('flex');
        mobileMenu?.classList.add('hidden');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
      } else {
        mobileMenu?.classList.remove('hidden');
        mobileMenu?.classList.add('flex');
        iconOpen?.classList.add('hidden');
        iconClose?.classList.remove('hidden');
      }
    });
  </script>

  <!-- Hero Section -->
  <section
    id="evento"
    class="min-h-screen flex items-center justify-center relative bg-black pt-32 overflow-hidden"
  >
    <!-- Video de fondo -->
    <video
      class="absolute inset-0 w-full h-full object-cover opacity-30"
      autoplay
      muted
      loop
      playsinline
    >
      <source src="/video.mp4" type="video/mp4" />
    </video>
    <!-- Overlay oscuro sobre el video -->
    <div class="absolute inset-0 bg-black/50"></div>

    <!-- Contenido -->
    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
      <img
        src="/logo1.png"
        alt="Heatrow Club"
        class="w-72 md:w-96 mx-auto mb-8 animate-flip3d"
      />
      <p class="text-xl md:text-2xl mb-8 text-gray-300">
        THE MUSIC THEY DON'T PLAY
      </p>

      <!-- CTA Button -->
      <a
        href="#entradas"
        class="inline-block bg-[oklch(50.5%_0.213_27.518)] hover:bg-[oklch(45%_0.213_27.518)] text-white px-12 py-4 rounded-none text-xl font-bold transition-all duration-300 shadow-xl uppercase tracking-wider"
      >
        Consigue tus entradas
      </a>
    </div>
  </section>

  <!--ABOUT US -->
  <section id="galeria" class="py-20 px-4 bg-black border-t border-[oklch(50.5%_0.213_27.518)] scroll-mt-28">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-4xl md:text-6xl font-black mb-4 text-center text-[oklch(50.5%_0.213_27.518)]">ABOUT US</h2>
      <div class="w-32 h-1 bg-[oklch(50.5%_0.213_27.518)] mx-auto mb-16"></div>

      <!-- Carousel -->
      <div class="relative overflow-hidden" id="carousel">
        <div class="carousel-inner flex transition-transform duration-500 ease-in-out" id="carousel-track">
          <!-- Slide 1 -->
          <div class="carousel-slide min-w-full">
            <div class="aspect-video bg-zinc-900 flex items-center justify-center border border-zinc-700">
              <span class="text-zinc-600 text-xl font-bold uppercase tracking-widest">Foto 1</span>
            </div>
          </div>
          <!-- Slide 2 -->
          <div class="carousel-slide min-w-full">
            <div class="aspect-video bg-zinc-900 flex items-center justify-center border border-zinc-700">
              <span class="text-zinc-600 text-xl font-bold uppercase tracking-widest">Foto 2</span>
            </div>
          </div>
          <!-- Slide 3 -->
          <div class="carousel-slide min-w-full">
            <div class="aspect-video bg-zinc-900 flex items-center justify-center border border-zinc-700">
              <span class="text-zinc-600 text-xl font-bold uppercase tracking-widest">Foto 3</span>
            </div>
          </div>
        </div>

        <!-- Prev / Next buttons -->
        <button id="carousel-prev" class="absolute left-4 top-1/2 -translate-y-1/2 bg-black/70 hover:bg-[oklch(50.5%_0.213_27.518)] text-white w-10 h-10 flex items-center justify-center transition-colors">
          &#8592;
        </button>
        <button id="carousel-next" class="absolute right-4 top-1/2 -translate-y-1/2 bg-black/70 hover:bg-[oklch(50.5%_0.213_27.518)] text-white w-10 h-10 flex items-center justify-center transition-colors">
          &#8594;
        </button>

        <!-- Dots -->
        <div class="flex justify-center gap-2 mt-6">
          <button class="carousel-dot w-2.5 h-2.5 rounded-full bg-[oklch(50.5%_0.213_27.518)]" data-index="0"></button>
          <button class="carousel-dot w-2.5 h-2.5 rounded-full bg-zinc-600" data-index="1"></button>
          <button class="carousel-dot w-2.5 h-2.5 rounded-full bg-zinc-600" data-index="2"></button>
        </div>
      </div>

      <!-- Texto About Us -->
      <div class="max-w-3xl mx-auto mt-16 text-center space-y-6">
        <p class="text-gray-300 text-lg leading-relaxed">
          Ubicada en la latente ciudad de Madrid, Heat Row es un proyecto que nace con la ambición de generar una comunidad de la mano del Hip-hop, el Trap y el Rap. Nuestro objetivo es hacer eco de este sonido y que las personas sientan que tienen un hogar al que ir, disfrutar y pertenecer. Esta idea emerge del sentimiento común de un grupo de amigos que motivados por una misma pasión desean compartirla y alimentarla con más gente en el camino, generando un ambiente positivo y cargado de energía.
        </p>
        <p class="text-gray-300 text-lg leading-relaxed">
          Desde un "Mosh Pit" a morir hasta vibear las melodías sintiéndote un "Pretty MF", nuestra propuesta es dar a escuchar más de lo que muchas fiestas en esta ciudad consideran que es el Hip-Hop.
        </p>
        <p class="text-white text-lg font-semibold leading-relaxed">
          Este es el punto de partida, la primera llama ya ha sido encendida, todo empieza ahora y tienes que ser parte de ello.
        </p>
      </div>
    </div>
  </section>

  <script>
    const track = document.getElementById('carousel-track') as HTMLElement;
    const dots = document.querySelectorAll('.carousel-dot');
    let current = 0;
    const total = 3;

    function goTo(index: number) {
      current = (index + total) % total;
      (track as HTMLElement).style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => {
        (d as HTMLElement).style.backgroundColor = i === current ? 'oklch(50.5% 0.213 27.518)' : 'rgb(82 82 82)';
      });
    }

    document.getElementById('carousel-prev')?.addEventListener('click', () => goTo(current - 1));
    document.getElementById('carousel-next')?.addEventListener('click', () => goTo(current + 1));
    dots.forEach(dot => dot.addEventListener('click', (e) => goTo(Number((e.target as HTMLElement).dataset.index))));
  </script>

  <!-- Upcoming Events Section -->
  <section id="entradas" class="py-20 px-4 bg-black border-t border-[oklch(50.5%_0.213_27.518)] scroll-mt-28">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-4xl md:text-6xl font-black mb-4 text-center text-[oklch(50.5%_0.213_27.518)]">UPCOMING EVENTS</h2>
      <div class="w-32 h-1 bg-[oklch(50.5%_0.213_27.518)] mx-auto mb-16"></div>

      <div class="flex justify-center">
        <div class="flex flex-col w-full max-w-sm">
          <img
            src="https://www.fourvenues.com/cdn-cgi/imagedelivery/kWuoTchaMsk7Xnc_FNem7A/8282eef4-28b4-4330-6561-831de5f1b400/w=1350"
            alt="Heatrow Club - Back to 2016"
            class="w-full aspect-[3/4] object-cover transition-all duration-500 hover:scale-[1.03] "
          />
          <div class="mt-4">
            <p class="text-white font-black text-xl uppercase leading-tight mb-3">
              BACK TO 2016!<br>SALA BAO BAO, MADRID — 27/03
            </p>
            <a
              href="/tickets"
              class="inline-block border border-[oklch(50.5%_0.213_27.518)] text-[oklch(50.5%_0.213_27.518)] hover:bg-[oklch(50.5%_0.213_27.518)] hover:text-white text-xs font-bold uppercase tracking-widest px-6 py-3 transition-colors w-fit"
            >
              COMPRAR ENTRADA
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Expandable Cards
  <section class="py-20 px-4 bg-black border-t border-[oklch(50.5%_0.213_27.518)]">
    <ExpandableCardDemo client:load />
  </section> -->

  <!-- Find Us -->
  <section id="contacto" class="py-20 px-8 bg-black border-t border-[oklch(50.5%_0.213_27.518)] scroll-mt-28">
    <div class="max-w-6xl mx-auto flex items-center justify-between">

      <!-- Left: info -->
      <div>
        <h2 class="text-5xl md:text-7xl font-black uppercase text-[oklch(50.5%_0.213_27.518)] mb-4">FIND US</h2>
        <p class="text-white font-bold uppercase tracking-widest text-sm mb-1">SALA BAO BAO</p>
        <p class="text-white font-bold uppercase tracking-widest text-sm mb-6">28003 MADRID</p>
        <a
          href="https://www.google.com/maps/place//data=!4m2!3m1!1s0xd4229e05cf83821:0xee32e69c702b521?sa=X&ved=1t:8290&ictx=111"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] text-sm underline underline-offset-4 transition-colors"
        >
          Ver Ubicación
        </a>
      </div>

      <!-- Right: map pin icon -->
      <svg class="w-24 h-24 md:w-32 md:h-32 text-[oklch(50.5%_0.213_27.518)]" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/>
      </svg>

    </div>
  </section>

  <!-- Footer -->
  <footer class="py-10 px-8 bg-black border-t border-[oklch(50.5%_0.213_27.518)]">
    <div class="w-full flex flex-col gap-8">

      <!-- Newsletter -->
      <div class="flex flex-col md:flex-row items-center justify-between gap-4 pb-8">
        <div>
          <p class="text-white font-black uppercase text-lg tracking-wide">ENTÉRATE ANTES QUE NADIE</p>
          <p class="text-zinc-500 text-sm">Suscríbete para saber primero cuándo salen las entradas.</p>
        </div>
        <form id="footer-newsletter" class="flex gap-0 w-full md:w-auto">
          <input
            type="email"
            name="email"
            placeholder="TU EMAIL"
            required
            class="bg-zinc-900 border border-zinc-700 focus:border-[oklch(50.5%_0.213_27.518)] text-white placeholder-zinc-500 px-4 py-2.5 text-sm outline-none transition-colors w-full md:w-64"
          />
          <button
            type="submit"
            class="bg-[oklch(50.5%_0.213_27.518)] hover:bg-[oklch(45%_0.213_27.518)] text-white font-bold uppercase tracking-widest text-xs px-5 py-2.5 transition-colors whitespace-nowrap"
          >
            SUSCRIBIRSE
          </button>
        </form>
      </div>

      <!-- Bottom row -->
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">

      <!-- Left: brand + links -->
      <div class="flex items-center gap-6 flex-wrap justify-center md:justify-start">
        <span class="text-[oklch(50.5%_0.213_27.518)] font-black uppercase tracking-widest text-sm">HEATROW CLUB</span>
        <a href="/" class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] text-sm transition-colors">Learn more</a>
        <a href="/contact" class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] text-sm transition-colors">Support</a>
      </div>

      <!-- Right: social icons -->
      <div class="flex items-center gap-5">
        <!-- Instagram -->
        <a
          href="https://www.instagram.com/heatrow.club/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] transition-colors"
          aria-label="Instagram de Heatrow"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"></path>
          </svg>
        </a>
        <!-- TikTok -->
        <a
          href="https://www.tiktok.com/@heatrow.club"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] transition-colors"
          aria-label="TikTok de Heatrow"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"></path>
          </svg>
        </a>

        <!-- Spotify -->
          <a
          href="https://open.spotify.com/intl-es/artist/13Aw4kvMgRhqQQndVGx9dc"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] transition-colors"
          aria-label="Spotify de Heatrow"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
          </svg>
        </a>

      </div>

    </div>
  </footer>

  <!-- Back to top -->
  <button
    id="back-to-top"
    class="fixed bottom-20 right-8 z-50 w-10 h-10 bg-[oklch(50.5%_0.213_27.518)] hover:bg-[oklch(45%_0.213_27.518)] text-white flex items-center justify-center transition-all duration-300 opacity-0 pointer-events-none"
    aria-label="Volver arriba"
  >
    &#8593;
  </button>

  <script>
    const btn = document.getElementById('back-to-top');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        btn?.classList.remove('opacity-0', 'pointer-events-none');
      } else {
        btn?.classList.add('opacity-0', 'pointer-events-none');
      }
    });
    btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  </script>


