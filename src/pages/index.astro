---
import Layout from "../layouts/Layout.astro";
import CookieBanner from "../components/ui/CookieBanner.astro";
import DjsSection from "../components/ui/DjsSection.jsx";
---

<Layout title="HEATROW CLUB | Home">
  <!-- Cookie Banner -->
  <CookieBanner />

  <!--Estilos para que el logo gire -->
  <style>
    @keyframes spin-slow {
      from {
        transform: rotate(0deg);
      }
      to {
        transform: rotate(360deg);
      }
    }
    .animate-spin-slow {
      animation: spin-slow 8s linear infinite;
    }
    @keyframes flip3d {
      0% {
        transform: perspective(600px) rotateY(0deg);
      }
      100% {
        transform: perspective(600px) rotateY(360deg);
      }
    }
    .animate-flip3d {
      animation: flip3d 4s linear infinite;
      transform-style: preserve-3d;
    }
  </style>

  <!-- Hero Section -->
  <section
    id="evento"
    class="min-h-screen flex items-center justify-center relative bg-black pt-32 overflow-hidden"
  >
    <!-- Video de fondo -->
    <video
      class="absolute inset-0 w-full h-full object-cover opacity-30"
      autoplay
      muted
      loop
      playsinline
    >
      <source src="/video1.mp4" type="video/mp4" />
    </video>
    <!-- Overlay oscuro sobre el video -->
    <div class="absolute inset-0 bg-black/50"></div>

    <!-- Contenido -->
    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">
      <img
        src="/logo1.png"
        alt="Heatrow Club"
        class="w-72 md:w-96 mx-auto mb-8 animate-flip3d"
      />
      <p class="text-xl md:text-2xl mb-8 text-gray-300">
        THE MUSIC THEY DON'T PLAY
      </p>

      <!-- CTA Button -->
      <a
        href="#entradas"
        class="inline-block bg-[oklch(50.5%_0.213_27.518)] hover:bg-[oklch(45%_0.213_27.518)] text-white px-12 py-4 rounded-none text-xl font-bold transition-all duration-300 shadow-xl uppercase tracking-wider"
      >
        Consigue tus entradas
      </a>
    </div>
  </section>

  <!--ABOUT US -->
  <section
    id="galeria"
    class="py-20 px-4 bg-black border-t border-[oklch(50.5%_0.213_27.518)] scroll-mt-28"
  >
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-4xl md:text-6xl font-black mb-4 text-center text-[oklch(50.5%_0.213_27.518)]"
      >
        ABOUT US
      </h2>
      <div class="w-32 h-1 bg-[oklch(50.5%_0.213_27.518)] mx-auto mb-16"></div>

      <!-- Carousel -->
      <div class="relative overflow-hidden" id="carousel" >
        <div
          class="carousel-inner flex transition-transform duration-500 ease-in-out"
          id="carousel-track"
        >
          <!-- Slide 1 -->
          <div class="carousel-slide min-w-full">
            <div
              class="aspect-video bg-zinc-900 flex items-center justify-center border border-red-600 overflow-hidden"
            >
              <img
                src="/gallery/foto5.png"
                class="w-full h-full object-cover"
                alt="Foto 1"
              />
            </div>
          </div>
          <!-- Slide 2 -->
          <div class="carousel-slide min-w-full">
            <div
              class="aspect-video bg-zinc-900 flex items-center justify-center border border-red-600 overflow-hidden"
            >
              <!-- Sustituye el span por una imagen si la agregas, con el mismo estilo -->
              <img
                src="/gallery/foto1.png"
                class="w-full h-full object-cover"
                alt="Foto 2"
              />
            </div>
          </div>
          <!-- Slide 3 -->
          <div class="carousel-slide min-w-full">
            <div
              class="aspect-video bg-zinc-900 flex items-center justify-center border border-red-600 overflow-hidden"
            >
              <!-- Sustituye el span por una imagen si la agregas, con el mismo estilo -->
              <img
                src="/gallery/foto4.png"
                class="w-full h-full object-cover"
                alt="Foto 3"
              />
            </div>
          </div>
        </div>

        <!-- Prev / Next buttons -->
        <button
          id="carousel-prev"
          class="absolute left-4 top-1/2 -translate-y-1/2 bg-black/70 hover:bg-[oklch(50.5%_0.213_27.518)] text-white w-10 h-10 flex items-center justify-center transition-colors"
        >
          &#8592;
        </button>
        <button
          id="carousel-next"
          class="absolute right-4 top-1/2 -translate-y-1/2 bg-black/70 hover:bg-[oklch(50.5%_0.213_27.518)] text-white w-10 h-10 flex items-center justify-center transition-colors"
        >
          &#8594;
        </button>

        <!-- Dots -->
        <div class="flex justify-center gap-2 mt-6">
          <button
            class="carousel-dot w-2.5 h-2.5 rounded-full bg-[oklch(50.5%_0.213_27.518)]"
            data-index="0"></button>
          <button
            class="carousel-dot w-2.5 h-2.5 rounded-full bg-zinc-600"
            data-index="1"></button>
          <button
            class="carousel-dot w-2.5 h-2.5 rounded-full bg-zinc-600"
            data-index="2"></button>
        </div>
      </div>

      <!-- Botón Ver más fotos -->
      <div class="flex justify-center mt-10">
        <a
          href="/gallery"
          class="inline-block border border-[oklch(50.5%_0.213_27.518)] text-[oklch(50.5%_0.213_27.518)] hover:bg-[oklch(50.5%_0.213_27.518)] hover:text-white text-xs font-bold uppercase tracking-widest px-6 py-3 transition-colors w-fit"
        >
          VER MÁS FOTOS
        </a>
      </div>

      <!-- Texto About Us -->
      <div class="max-w-3xl mx-auto mt-16 text-center space-y-6">
        <p class="text-gray-300 text-lg leading-relaxed">
          Ubicada en la latente ciudad de Madrid, Heat Row es un proyecto que
          nace con la ambición de generar una comunidad de la mano del Hip-hop,
          el Trap y el Rap. Nuestro objetivo es hacer eco de este sonido y que
          las personas sientan que tienen un hogar al que ir, disfrutar y
          pertenecer. Esta idea emerge del sentimiento común de un grupo de
          amigos que motivados por una misma pasión desean compartirla y
          alimentarla con más gente en el camino, generando un ambiente positivo
          y cargado de energía.
        </p>
        <p class="text-gray-300 text-lg leading-relaxed">
          Desde un "Mosh Pit" a morir hasta vibear las melodías sintiéndote un
          "Pretty MF", nuestra propuesta es dar a escuchar más de lo que muchas
          fiestas en esta ciudad consideran que es el Hip-Hop.
        </p>
        <p class="text-white text-lg font-semibold leading-relaxed">
          Este es el punto de partida, la primera llama ya ha sido encendida,
          todo empieza ahora y tienes que ser parte de ello.
        </p>
      </div>
    </div>
  </section>

  <!-- Script para que funcione el carousel -->
  <script>
    const track = document.getElementById("carousel-track") as HTMLElement;
    const dots = document.querySelectorAll(".carousel-dot");
    let current = 0;
    const total = 3;

    function goTo(index: number) {
      current = (index + total) % total;
      (track as HTMLElement).style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => {
        (d as HTMLElement).style.backgroundColor =
          i === current ? "oklch(50.5% 0.213 27.518)" : "rgb(82 82 82)";
      });
    }

    document
      .getElementById("carousel-prev")
      ?.addEventListener("click", () => goTo(current - 1));
    document
      .getElementById("carousel-next")
      ?.addEventListener("click", () => goTo(current + 1));
    dots.forEach((dot) =>
      dot.addEventListener("click", (e) =>
        goTo(Number((e.target as HTMLElement).dataset.index)),
      ),
    );
  </script>

  <!-- Upcoming Events Section -->
  <section
    id="entradas"
    class="py-20 px-4 bg-black border-t border-[oklch(50.5%_0.213_27.518)] scroll-mt-28"
  >
    <div class="max-w-6xl mx-auto">
      <h2
        class="text-4xl md:text-6xl font-black mb-4 text-center text-[oklch(50.5%_0.213_27.518)]"
      >
        UPCOMING EVENTS
      </h2>
      <div class="w-32 h-1 bg-[oklch(50.5%_0.213_27.518)] mx-auto mb-16"></div>

      <div class="flex justify-center">
        <div class="flex flex-col w-full max-w-sm">
          <video
            autoplay
            muted
            loop
            playsinline
            class="w-full aspect-[3/4] object-cover border border-red-600"
          >
            <source src="/videoye.mp4" type="video/mp4" />
            Tu navegador no soporta el elemento video
          </video>
          <div class="mt-4">
            <p
              class="text-white font-black text-xl uppercase leading-tight mb-3"
            >
              KANYE WEST AFTER CONCERT<br />TEATRO MAGNO, MADRID — 30/07
            </p>
            <a
              href="/tickets"
              class="inline-block border border-[oklch(50.5%_0.213_27.518)] text-[oklch(50.5%_0.213_27.518)] hover:bg-[oklch(50.5%_0.213_27.518)] hover:text-white text-xs font-bold uppercase tracking-widest px-6 py-3 transition-colors w-fit"
            >
              COMPRAR ENTRADA
            </a>
          </div>
        </div>
      </div>
    </div>
    <!-- <DjsSection client:load /> -->
  </section>

  <!-- Find Us -->
  <section
    id="contacto"
    class="py-20 px-8 bg-black border-t border-[oklch(50.5%_0.213_27.518)] scroll-mt-28"
  >
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <!-- Left: info -->
      <div>
        <h2
          class="text-5xl md:text-7xl font-black uppercase text-[oklch(50.5%_0.213_27.518)] mb-4"
        >
          FIND US
        </h2>
        <p class="text-white font-bold uppercase tracking-widest text-sm mb-1">
          TEATRO MAGNO
        </p>
        <p class="text-white font-bold uppercase tracking-widest text-sm mb-6">
          28014 MADRID
        </p>
        <a
          href=https://www.google.com/maps/place/Teatro+Magno/@40.4173074,-3.6983218,17z/data=!3m1!4b1!4m6!3m5!1s0xd42291c08455f2d:0x484149f164cdd1eb!8m2!3d40.4173074!4d-3.6983218!16s%2Fg%2F11rdbdrd5v?entry=ttu&g_ep=EgoyMDI2MDQwNS4wIKXMDSoASAFQAw%3D%3D
          target="_blank"
          rel="noopener noreferrer"
          class="text-[oklch(50.5%_0.213_27.518)] hover:text-[oklch(57.7%_0.245_27.325)] text-sm underline underline-offset-4 transition-colors"
        >
          Ver Ubicación
        </a>
      </div>

      <!-- Right: map -->
      <div class="w-64 h-64 md:w-80 md:h-80 overflow-hidden border border-[oklch(50.5%_0.213_27.518)]">
        <iframe
          width="100%"
          height="100%"
          frameborder="0"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3037.61804948712!2d-3.7008967234930426!3d40.41731145560309!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd42291c08455f2d%3A0x484149f164cdd1eb!2sTeatro%20Magno!5e0!3m2!1ses!2ses!4v1775568497175!5m2!1ses!2ses" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </section>
</Layout>
